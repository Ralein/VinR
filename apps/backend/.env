
# App
APP_NAME=VinR API
APP_VERSION=0.1.0
DEBUG=true

# Database (Neon PostgreSQL — get your connection string from neon.tech console)
DATABASE_URL=postgresql+asyncpg://user:password@ep-your-endpoint.us-east-2.aws.neon.tech/vinr_db?sslmode=require

# Redis
REDIS_URL=redis://localhost:6379/0


# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-your-key
CLAUDE_MODEL=claude-sonnet-4-20250514

# Firebase Cloud Messaging
FCM_SERVER_KEY=

# AWS S3 (Audio files)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=vinr-media
AWS_REGION=us-east-1

# CORS
CORS_ORIGINS=["http://localhost:8081","http://localhost:19006"]
