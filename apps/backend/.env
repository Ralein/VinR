APP_NAME="VinR API"
APP_VERSION="0.1.0"
DEBUG=True

# Neon Cloud PostgreSQL Connection String
# Replace this with your actual Neon database URL
DATABASE_URL="postgresql+asyncpg://<username>:<password>@<ep-name>-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Redis
REDIS_URL="redis://localhost:6379/0"
CELERY_BROKER_URL="redis://localhost:6379/1"

# JWT Authentication
# Run `openssl rand -hex 32` to generate a secure key for production
SECRET_KEY="replace_me_with_a_highly_secure_randomly_generated_string_for_vinr"
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
FRONTEND_URL="exp://localhost:8081"

# OAuth (Google, etc.)
GOOGLE_CLIENT_ID=""

# SMTP settings for outgoing emails
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
EMAILS_FROM_EMAIL="noreply@vinrmobile.com"

# AI/ML
ANTHROPIC_API_KEY=""

# AWS S3 (for image/video storage)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET="vinr-media"
AWS_REGION="us-east-1"

# External APIs
YOUTUBE_API_KEY=""
EVENTBRITE_API_KEY=""
MEETUP_API_KEY=""
EXPO_PUSH_URL="https://exp.host/--/api/v2/push/send"
